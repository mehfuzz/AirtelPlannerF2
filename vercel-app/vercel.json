{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.py",
      "use": "@vercel/python"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "^/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "SUPABASE_URL": "https://qevlsnzpmbzwhsazcvpr.supabase.co",
    "SUPABASE_ANON_KEY": "sb_publishable_kUYN75ZOKexkPL6vsXkGlQ_bC25Nf_V",
    "SUPABASE_SERVICE_KEY": "sb_secret_xFRb3NHBqwCVzl-_wcugsg__ysVBZST",
    "JWT_SECRET": "@jwt_secret"
  }
}
